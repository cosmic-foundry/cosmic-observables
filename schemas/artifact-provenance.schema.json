{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-foundry.github.io/cosmic-observables/schemas/artifact-provenance.schema.json",
  "title": "Validation artifact provenance sidecar",
  "$comment": "A provenance sidecar records how one normalized validation artifact was produced. It is distinct from validation-set build_plan, which records planning intent. See ADR-0002.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "validation_set_id",
    "built_at",
    "adapter",
    "upstream",
    "artifact"
  ],
  "properties": {
    "validation_set_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "ID of the validation-set manifest this artifact implements."
    },
    "built_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp for artifact generation."
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["script", "version"],
      "properties": {
        "script": {
          "$ref": "#/$defs/repo_relative_path",
          "description": "Repository-relative path to the adapter script that generated the artifact."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Git commit SHA or tag identifying the adapter version at build time."
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalog",
        "release",
        "url",
        "retrieved_at",
        "content_hash"
      ],
      "properties": {
        "catalog": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Catalog manifest ID for the upstream input."
        },
        "release": {
          "type": "string",
          "minLength": 1,
          "description": "Upstream release identifier, tag, version, or commit SHA."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL from which the upstream input was fetched."
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp for upstream retrieval."
        },
        "content_hash": {
          "$ref": "#/$defs/sha256_hash",
          "description": "Hash of the fetched upstream input."
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "content_hash", "row_count"],
      "properties": {
        "path": {
          "$ref": "#/$defs/repo_relative_path",
          "description": "Repository-relative path or planned storage path for the generated artifact."
        },
        "content_hash": {
          "$ref": "#/$defs/sha256_hash",
          "description": "Hash of the generated artifact."
        },
        "row_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of table rows or top-level records in the generated artifact."
        }
      }
    }
  },
  "$defs": {
    "repo_relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "sha256_hash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "value": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "Lowercase hexadecimal SHA-256 digest."
        }
      }
    }
  }
}
