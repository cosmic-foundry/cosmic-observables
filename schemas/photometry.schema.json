{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-foundry.github.io/cosmic-observables/schemas/photometry.schema.json",
  "title": "Normalized photometry artifact schema",
  "$comment": "Defines the required columns and formats for normalized photometric light-curve artifacts (Tidy/Long format).",
  "type": "object",
  "required": ["columns"],
  "properties": {
    "columns": {
      "type": "object",
      "required": ["object_id", "mjd", "magnitude", "magnitude_err", "filter"],
      "properties": {
        "object_id": { "type": "string", "description": "Repo-internal slug ID (e.g. sn-2011fe)." },
        "mjd": { "type": "string", "description": "Modified Julian Date of the observation." },
        "magnitude": { "type": "string", "description": "Apparent magnitude." },
        "magnitude_err": { "type": "string", "description": "1-sigma uncertainty on the magnitude." },
        "filter": { "type": "string", "description": "Identifier resolving to a filter manifest (e.g. 'csp-dr3-b')." },
        "magnitude_system": { "type": "string", "description": "Override for the magnitude system if it differs from the filter default." },
        "time_system": {
          "type": "string",
          "enum": ["MJD", "JD", "BJD"],
          "default": "MJD"
        },
        "data_treatment": {
          "type": "object",
          "additionalProperties": false,
          "description": "Flags for applied physical corrections.",
          "properties": {
            "galactic_extinction_corrected": { "type": "boolean", "default": false },
            "k_corrected": { "type": "boolean", "default": false }
          }
        }
      }
    }
  }
}
