{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-foundry.github.io/cosmic-observables/schemas/source.schema.json",
  "title": "Observational source manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "kind",
    "domain",
    "role",
    "homepage",
    "status",
    "provenance",
    "data_products",
    "known_caveats",
    "next_actions"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "title": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["archive", "survey-release", "compilation", "bibliographic-service"]
    },
    "domain": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "role": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "api_or_download": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "bibcode": { "type": "string" },
          "doi": { "type": "string" }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "planned", "ingesting", "available", "deprecated"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "accessed", "license_or_terms"],
      "properties": {
        "authority": { "type": "string" },
        "accessed": { "type": "string", "format": "date" },
        "license_or_terms": { "type": "string" }
      }
    },
    "data_products": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "known_caveats": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
